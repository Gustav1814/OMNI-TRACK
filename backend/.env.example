# ============================================================
# OmniTrack AI — Environment Configuration
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://omnitrack:omnitrack_secret@localhost:5432/omnitrack_db
# Detections/embeddings reference cameras.id — create a camera (POST /api/cameras) whose id matches
# the camera_id you pass to POST /api/detection/start/{camera_id}, or detection rows will not persist (see server logs).

# --- JWT ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES-256 Encryption ---
AES_SECRET_KEY=0123456789abcdef0123456789abcdef

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI Models ---
# Weights are gitignored; run: python scripts/download_default_weights.py
MODEL_WEIGHTS_DIR=model_weight
DEFAULT_YOLO_MODEL=yolo11n.pt
YOLO_MODEL=yolo11n.pt
YOLO_MODEL_PATH=yolo11n.pt
YOLO_CONFIDENCE=0.5
YOLO_NMS_THRESHOLD=0.45
# Optional second YOLO (products/SKUs). Throttled; not tracked or Re-ID'd. Leave unset to disable.
# PRODUCT_YOLO_PATH=your_product_model.pt
# PRODUCT_YOLO_CONFIDENCE=0.45
# PRODUCT_DETECT_EVERY_N_FRAMES=3
# PRODUCT_MAX_DETECTIONS_PER_FRAME=25
FIRE_MODEL_PATH=fire-smoke.pt
# Must be a dedicated fire/smoke-trained .pt — never the same file as YOLO_MODEL_PATH or PRODUCT_YOLO_PATH.
# Fire inference is OFF unless you enable it per-feed in the UI or set:
ENABLE_FIRE_DETECTION=false
FIRE_DETECTION_CONFIDENCE=0.58
REID_MODEL_NAME=osnet_x0_25
# Re-ID tuning: face often not visible / same height and clothing
REID_SIMILARITY_THRESHOLD=0.6
REID_EMBEDDINGS_PER_ID=5
MAX_CAMERAS=4
RUNTIME_PROFILE=laptop
TRACKER_DEFAULT=botsort.yaml
TRACKER_REID=false
REID_BACKEND=torchreid
REID_WEIGHTS=
ENABLE_SAM2=false
SAM2_WEIGHTS=sam2_b.pt
DECODE_IMGSZ=480
EVENT_BUS_BACKEND=redis
# pgvector = vectors in Postgres + similarity search there. faiss/qdrant = extra index; embeddings still saved to Postgres.
VECTOR_STORE_BACKEND=pgvector
ENABLE_MEDIAPIPE=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=omnitrack_embeddings
MEMORY_GUARD_MB=0
STORAGE_FREE_MIN_MB=1024
FOOTAGE_RETENTION_GB=20

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- App ---
APP_NAME=OmniTrack AI
APP_VERSION=1.0.0
DEBUG=true
